# ─── Client 환경 변수 ───
# Vite에서는 VITE_ 접두사가 필수
VITE_API_URL=http://localhost:4000/api

# Kakao Maps API (https://developers.kakao.com 내 애플리케이션 > 앱 키 > JavaScript 키)
VITE_KAKAO_MAP_KEY=your_kakao_map_js_key

# Google Maps API (https://console.cloud.google.com)
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key
